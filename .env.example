# PostgreSQL
DATABASE_URL=postgresql+psycopg://brainwidebench:changeme@db:5432/brainwidebench
POSTGRES_USER=brainwidebench
POSTGRES_PASSWORD=changeme

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# Auth0  (set AUTH0_DOMAIN=dev to disable JWT verification locally)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.brainwidebench.org

# AWS / S3
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
S3_BUCKET=brainwidebench-submissions

# Ground truth oracle (S3 prefix, or a local dir for dev)
S3_GT_PREFIX=ground-truth/ts1

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*
